# Minimal kernel config for oci2bin cloud-hypervisor microVM backend.
# Based on Linux 6.1 LTS.  Build with: make kernel
#
# Key requirements:
#   - CONFIG_VIRTIO_MMIO: cloud-hypervisor uses MMIO transport, not PCI
#   - CONFIG_BLK_DEV_INITRD: initramfs as primary rootfs (no block device needed)
#   - CONFIG_VSOCKETS + CONFIG_VIRTIO_VSOCKETS: exit code forwarding
#   - CONFIG_9P_FS + CONFIG_NET_9P_VIRTIO: virtiofs mounts (-v HOST:CTR)
#   - CONFIG_MODULES=n: no loadable modules in guest kernel

# ── Architecture / platform ───────────────────────────────────────────────────
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_NR_CPUS=16
CONFIG_HYPERVISOR_GUEST=y
CONFIG_KVM_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_X86_X2APIC=y

# ── Initramfs (primary rootfs — no block device needed) ───────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_RD_BZIP2=n
CONFIG_RD_LZMA=n
CONFIG_RD_XZ=n
CONFIG_RD_LZO=n
CONFIG_RD_LZ4=n
CONFIG_RD_ZSTD=n

# ── Virtio devices ────────────────────────────────────────────────────────────
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=n
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_HW_RANDOM_VIRTIO=y

# ── Vsock (exit code forwarding from guest) ───────────────────────────────────
CONFIG_VSOCKETS=y
CONFIG_VSOCKETS_DIAG=n
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_TMPFS=y
CONFIG_TMPFS_XATTR=y
CONFIG_OVERLAY_FS=y
CONFIG_EXT2_FS=y
CONFIG_EXT2_FS_XATTR=n
CONFIG_EXT3_FS=n
CONFIG_EXT4_FS=n

# virtio-fs / 9p (for -v host dir mounts)
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=n
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_NET_9P_DEBUG=n

CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ── Namespaces and security ───────────────────────────────────────────────────
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUPS=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# ── Networking (minimal) ──────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=n
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NET_CORE=y
CONFIG_NETDEVICES=y

# ── Serial console ────────────────────────────────────────────────────────────
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4

# ── No loadable modules ───────────────────────────────────────────────────────
CONFIG_MODULES=n

# ── Disable unnecessary subsystems ───────────────────────────────────────────
CONFIG_ACPI=n
CONFIG_X86_ACPI_CPUFREQ=n
CONFIG_SOUND=n
CONFIG_USB=n
CONFIG_WIRELESS=n
CONFIG_BLUETOOTH=n
CONFIG_HID=n
CONFIG_INPUT=n
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_VGA_CONSOLE=n
CONFIG_AGP=n
CONFIG_PCCARD=n
CONFIG_PCMCIA=n
CONFIG_ISDN=n
CONFIG_ATA=n
CONFIG_SCSI=n
CONFIG_NFS_FS=n
CONFIG_SMB_SERVER=n

# ── Disable debug / tracing ───────────────────────────────────────────────────
CONFIG_DEBUG_KERNEL=n
CONFIG_FTRACE=n
CONFIG_KPROBES=n
CONFIG_PERF_EVENTS=n
CONFIG_TRACING=n
CONFIG_KALLSYMS=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_KGDB=n
