#!/usr/bin/env bash
# oci2bin — package a Docker image as a self-contained ELF+tar polyglot
#
# Usage:
#   oci2bin [--arch ARCH] <image[:tag]> [output]
#   oci2vm  [--arch ARCH] <image[:tag]> [output]   (VM mode by default)
#   oci2bin exec <PID> [--] <CMD> [ARGS...]
#   oci2bin inspect <binary>
#   oci2bin sign   --key KEY.pem  --in BINARY [--out BINARY]
#   oci2bin verify --key PUB.pem  --in BINARY
#   oci2bin sign-file --key KEY.pem --in FILE --out SIG
#   oci2bin verify-file --key PUB.pem --in FILE --sig SIG
#   oci2bin pod run [--net shared] [--ipc shared] BINARY [BINARY ...]
#   oci2bin run [BUILD_OPTS...] IMAGE [-- RUNTIME_ARGS...]
#   oci2bin systemd BINARY [--user] [--restart always|on-failure|no]
#   oci2bin healthcheck BINARY [--pid PID]
#   oci2bin top [--once] [--interval SEC]
#   oci2bin list [--json]
#   oci2bin prune [--dry-run]
#   oci2bin diff <binary1> <binary2>
#   oci2bin reconstruct <image-or-file> [--output PATH] [--no-strip]
#
# The output file runs as a rootless container AND can be imported with
# docker load. It accepts the same runtime flags as the embedded loader:
#
#   ./output [OPTIONS] [-- CMD [ARGS...]]
#   ./output [OPTIONS] CMD [ARGS...]
#
# Build options:
#   --arch ARCH           Target architecture: x86_64 (default), aarch64, or
#                         'all' (builds both and emits a wrapper shell script).
#                         Cross-compilation requires the matching cross-
#                         compiler (aarch64-linux-gnu-gcc) to be in PATH.
#   --cache               Cache the output binary; skip rebuild if already built
#   --layer IMAGE         Merge additional image layers on top of the base image
#                         (may be repeated; layers are applied in order)
#   --strip               Remove docs/man/locale/cache from the image before packaging
#   --strip-prefix PREFIX Strip a custom path prefix instead of the built-in defaults
#                         (may be repeated; each use implies --strip)
#   --strip-auto          Auto-detect package managers and add their cache paths to --strip
#   --add-file HOST:CONTAINER
#                         Inject a host file into the image at build time (repeatable)
#   --add-dir  HOST:CONTAINER
#                         Inject a host directory recursively (repeatable)
#   --oci-dir DIR         Use an OCI image layout directory instead of docker save
#                         (skips docker pull/save; IMAGE arg used only for naming)
#   --kernel PATH         Embed a vmlinux kernel blob (enables --vm mode)
#   --initramfs PATH      Embed a pre-built initramfs cpio.gz blob
#   --libkrun             Force libkrun loader (default: auto-detected)
#   --no-libkrun          Force static loader even if libkrun is available
#   --embed-loader-layer  Embed loader as an extra OCI layer (<loader-dir>/loader)
#                         so the binary can be reconstructed via 'reconstruct'
#   --embed-loader-labels Embed loader as chunked base64 image config labels
#                         (no filesystem layer; use when layer pollution matters)
#   --label-chunk-size N  Binary bytes per label chunk for --embed-loader-labels
#                         (default: 6144 → ~8 KB base64 per label)
#   --loader-dir DIR      Directory inside container for embedded loader binary
#                         (default: .oci2bin; applies to --embed-loader-layer)
#   --label-prefix PREFIX Label key prefix for all embed metadata labels
#                         (default: oci2bin.loader; change to avoid naming conflicts)
#   --self-update-url URL Embed a signed update-manifest URL into the binary
#   --pin-digest DIGEST|ALGO:auto
#                         Embed a pinned canonical digest for runtime integrity checks
#
# Runtime options (passed directly to the output binary):
#   -v HOST:CONTAINER     Bind mount a host path into the container
#   --secret HOST_FILE[:CONTAINER_PATH]
#                         Bind mount a host file read-only into the container;
#                         defaults to /run/secrets/<basename> (may be repeated)
#   --entrypoint PATH     Override the image entrypoint
#   --workdir PATH        Set the working directory inside the container
#   --net host|none|slirp|pasta|slirp:H:C
#                         Network: host (default), none (isolated),
#                         slirp (slirp4netns), pasta, or slirp with port forward
#   --read-only           Mount rootfs read-only via overlayfs
#   --overlay-persist DIR Persist overlay upper layer to DIR (state survives restarts)
#   --ssh-agent           Forward host SSH_AUTH_SOCK into the container
#   -p HOST_PORT:CTR_PORT Publish a port from the container to the host;
#                         implies --net slirp (may be repeated)
#   --add-host HOST:IP    Inject a hostname→IP entry into /etc/hosts
#   --dns IP              Override DNS server in resolv.conf (may be repeated)
#   --dns-search DOMAIN   Add DNS search domain (may be repeated)
#   --no-seccomp          Disable the default seccomp syscall filter
#   --seccomp-profile FILE
#                         Apply a Docker-compatible JSON seccomp profile
#   --no-auto-tmpfs       Do not auto-mount /run as tmpfs with --read-only
#   --security-opt apparmor=PROFILE
#                         Apply AppArmor profile (build with -DHAVE_APPARMOR)
#   --security-opt label=TYPE:VAL
#                         Set SELinux exec label (build with -DHAVE_SELINUX)
#   --user UID[:GID]      Run as this numeric UID (and optional GID)
#   --hostname NAME       Set the hostname inside the container
#   --cap-drop CAP        Drop a Linux capability (or 'all' to drop all)
#   --cap-add CAP         Add an ambient capability (use after --cap-drop all)
#   --device /dev/PATH[:CONTAINER_PATH]
#                         Expose a host device inside the container
#   --init                Run a zombie-reaping init as PID 1
#   --detach, -d          Run container in background; print PID to stdout
#   --memory SIZE         Limit memory (e.g. 512m, 2g) via cgroup v2
#   --cpus FLOAT          Limit CPU fraction (e.g. 0.5) via cgroup v2
#   --pids-limit N        Limit total PIDs via cgroup v2
#   --verify-key PATH     Verify signature before extraction (abort if invalid)
#   --env-file FILE       Load KEY=VALUE pairs from FILE (additive with -e)
#   --tmpfs PATH          Mount a fresh tmpfs at PATH inside the container
#   --ulimit TYPE=N       Set resource limit (nofile, nproc, cpu, as, fsize)
#   --config PATH         Load options from a key=value config file
#   --debug               Emit verbose runtime debug diagnostics
#   --                    End of options; remaining args are CMD
#
# Cache subcommands:
#   list [--json]         List all cached binaries with image name, size, date
#   prune [--dry-run]     Remove outdated cache entries (keep newest per image)
#   diff <b1> <b2>        Show filesystem diff between two oci2bin binaries
#   run IMAGE [...]       Build to a temp file and execute it once
#   systemd BINARY        Emit a ready-to-use systemd unit file
#   healthcheck BINARY    Run the embedded OCI HEALTHCHECK command
#   top                   Live stats for named running containers
#   reconstruct <src>     Rebuild polyglot from an image built with
#                         --embed-loader-layer or --embed-loader-labels;
#                         <src> is a Docker image name or a .tar/.img file
#                         Options: --output PATH, --no-strip,
#                                  --label-prefix PREFIX
#
# Examples:
#   oci2bin alpine:latest               # -> alpine_latest (host arch)
#   oci2bin --arch aarch64 alpine:latest # -> alpine_latest (aarch64 binary)
#   oci2bin ubuntu:22.04 my-ubuntu      # -> my-ubuntu (explicit name)
#
#   ./alpine_latest                     # run default shell
#   ./alpine_latest /bin/ls /           # override CMD
#   ./alpine_latest --entrypoint /bin/sh -c "echo hi"
#   ./alpine_latest -v /data:/mnt /bin/ls /mnt
#
#   oci2bin list                        # show cached binaries
#   oci2bin prune                       # remove old cache entries
#   oci2bin diff alpine_latest redis_7  # compare two binaries
#   oci2bin --embed-loader-layer redis:7-alpine  # embed loader for reconstruction
#   oci2bin reconstruct redis:7-alpine  # rebuild from Docker image

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OCI2BIN_HOME="${OCI2BIN_HOME:-$SCRIPT_DIR}"

# ── oci2vm mode ───────────────────────────────────────────────────────────
# When invoked as "oci2vm" the output binary is named oci2vm_<image> so that
# the loader's own basename check fires and VM mode is the runtime default.
_OCI2BIN_BASENAME="$(basename "$0")"
OCI2VM_MODE=0
if [[ "$_OCI2BIN_BASENAME" == "oci2vm" ]]; then
    OCI2VM_MODE=1
fi

usage() {
    sed -n '/^#!/d; /^#/!q; s/^# \?//p' "$0"
    exit 1
}

container_state_dir_or_die() {
    python3 - "${HOME:-}" <<'PYEOF'
import os
import sys

home = sys.argv[1]
if not home or not os.path.isabs(home):
    print("oci2bin: HOME must be an absolute path", file=sys.stderr)
    sys.exit(1)

home_parts = [part for part in home.split("/") if part]
if any(part == ".." for part in home_parts):
    print("oci2bin: HOME must not contain '..' components", file=sys.stderr)
    sys.exit(1)

state_dir = os.path.join(home, ".cache", "oci2bin", "containers")
parts = [part for part in state_dir.split("/") if part]
cur = "/"
for part in parts:
    cur = os.path.join(cur, part)
    try:
        os.lstat(cur)
    except FileNotFoundError:
        continue
    except OSError as exc:
        print(f"oci2bin: lstat {cur}: {exc}", file=sys.stderr)
        sys.exit(1)
    if os.path.islink(cur):
        print(f"oci2bin: state path contains symlink component: {cur}",
              file=sys.stderr)
        sys.exit(1)

print(state_dir)
PYEOF
}

# ── exec subcommand ──────────────────────────────────────────────────────
# Usage: oci2bin exec <PID> [--] <CMD> [ARGS...]
# Joins the namespaces of a running container by PID and executes CMD inside.
# Requires nsenter(1) from util-linux.

if [[ "${1:-}" == "exec" ]]; then
    shift
    if [[ $# -lt 2 ]]; then
        echo "Usage: oci2bin exec <PID> [--] <CMD> [ARGS...]" >&2
        echo "  Joins the namespaces of the container identified by PID" >&2
        echo "  and executes CMD inside it." >&2
        exit 1
    fi
    EXEC_PID="$1"; shift
    # Validate PID is numeric
    if ! [[ "$EXEC_PID" =~ ^[0-9]+$ ]]; then
        echo "oci2bin exec: PID must be a positive integer, got: $EXEC_PID" >&2
        exit 1
    fi
    # Strip leading '--' separator if present
    [[ "${1:-}" == "--" ]] && shift
    if [[ $# -lt 1 ]]; then
        echo "oci2bin exec: CMD is required after PID" >&2
        exit 1
    fi
    need nsenter
    # Join user, mount, pid, uts, and ipc namespaces of the target process.
    # --preserve-credentials keeps the user namespace mapping correct.
    exec nsenter \
        --target "$EXEC_PID" \
        --user \
        --mount \
        --pid \
        --uts \
        --ipc \
        --preserve-credentials \
        -- "$@"
fi

# ── inspect subcommand ────────────────────────────────────────────────────

if [[ "${1:-}" == "inspect" ]]; then
    shift
    if [[ $# -lt 1 ]]; then
        echo "Usage: oci2bin inspect <binary>" >&2
        exit 1
    fi
    exec python3 "$OCI2BIN_HOME/scripts/inspect_image.py" "$@"
fi

# ── sign subcommand ───────────────────────────────────────────────────────

if [[ "${1:-}" == "sign" ]]; then
    shift
    exec python3 "$OCI2BIN_HOME/scripts/sign_binary.py" sign "$@"
fi

# ── verify subcommand ─────────────────────────────────────────────────────

if [[ "${1:-}" == "verify" ]]; then
    shift
    exec python3 "$OCI2BIN_HOME/scripts/sign_binary.py" verify "$@"
fi

# ── detached file signing subcommands ──────────────────────────────────────

if [[ "${1:-}" == "sign-file" ]]; then
    shift
    exec python3 "$OCI2BIN_HOME/scripts/sign_binary.py" sign-file "$@"
fi

if [[ "${1:-}" == "verify-file" ]]; then
    shift
    exec python3 "$OCI2BIN_HOME/scripts/sign_binary.py" verify-file "$@"
fi

# ── list subcommand ───────────────────────────────────────────────────────

if [[ "${1:-}" == "list" ]]; then
    shift
    CACHE_ROOT="$HOME/.cache/oci2bin"
    LIST_JSON=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) LIST_JSON=1; shift ;;
            *) echo "oci2bin list: unknown option: $1" >&2; exit 1 ;;
        esac
    done
    if [[ ! -d "$CACHE_ROOT" ]]; then
        echo "oci2bin: no cache found at $CACHE_ROOT" >&2
        exit 0
    fi
    python3 - "$CACHE_ROOT" "$LIST_JSON" "$OCI2BIN_HOME" <<'PYEOF'
import json, os, sys

cache_root = sys.argv[1]
want_json  = sys.argv[2] == "1"
home       = sys.argv[3]
inspect    = os.path.join(home, "scripts", "inspect_image.py")

import importlib.util, types

# Load inspect_image module without executing main()
spec = importlib.util.spec_from_file_location("inspect_image", inspect)
mod  = importlib.util.module_from_spec(spec)
spec.loader.exec_module(mod)

entries = []
for name in sorted(os.listdir(cache_root)):
    out = os.path.join(cache_root, name, "output")
    if not os.path.isfile(out):
        continue
    file_size = os.path.getsize(out)
    mtime = os.path.getmtime(out)
    meta = mod.read_meta_block(out) or {}
    if "image" not in meta:
        try:
            oci = mod.read_oci_data(out)
            tags, _, _ = mod.parse_config(oci)
            meta["image"] = tags[0] if tags else "unknown"
        except SystemExit:
            meta["image"] = "unknown"
    meta["size"]  = file_size
    meta["mtime"] = mtime
    meta["cache_dir"] = name
    entries.append(meta)

# Sort by build timestamp descending, fall back to mtime
def sort_key(e):
    ts = e.get("timestamp") or ""
    return (ts, e.get("mtime", 0))

entries.sort(key=sort_key, reverse=True)

if want_json:
    print(json.dumps(entries, indent=2))
else:
    # Print table
    FMT = "%-32s %-14s %10s  %s"
    print(FMT % ("IMAGE", "DIGEST", "SIZE", "BUILT"))
    print("-" * 76)
    for e in entries:
        image  = (e.get("image") or "unknown")[:32]
        digest = (e.get("digest","").split(":")[-1])[:12] if e.get("digest") else "-" * 12
        sz     = e["size"]
        if sz >= 1024*1024:
            size_s = f"{sz/(1024*1024):.1f} MB"
        elif sz >= 1024:
            size_s = f"{sz/1024:.1f} KB"
        else:
            size_s = f"{sz} B"
        built  = (e.get("timestamp") or "-")[:19]
        print(FMT % (image, digest, size_s, built))
PYEOF
    exit 0
fi

# ── prune subcommand ──────────────────────────────────────────────────────

if [[ "${1:-}" == "prune" ]]; then
    shift
    CACHE_ROOT="$HOME/.cache/oci2bin"
    PRUNE_DRY_RUN=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) PRUNE_DRY_RUN=1; shift ;;
            *) echo "oci2bin prune: unknown option: $1" >&2; exit 1 ;;
        esac
    done
    if [[ ! -d "$CACHE_ROOT" ]]; then
        echo "oci2bin: no cache found at $CACHE_ROOT" >&2
        exit 0
    fi
    python3 - "$CACHE_ROOT" "$PRUNE_DRY_RUN" "$OCI2BIN_HOME" <<'PYEOF'
import json, os, shutil, sys

cache_root = sys.argv[1]
dry_run    = sys.argv[2] == "1"
home       = sys.argv[3]
inspect    = os.path.join(home, "scripts", "inspect_image.py")

import importlib.util

spec = importlib.util.spec_from_file_location("inspect_image", inspect)
mod  = importlib.util.module_from_spec(spec)
spec.loader.exec_module(mod)

# Collect all cache entries keyed by base image name
# Cache dir names look like "redis_7-alpine_abc123def456" — strip the trailing
# _<12hexchars> digest suffix to get the image group key.
import re

groups = {}  # image_key -> list of (mtime, size, cache_dir_path)
for name in os.listdir(cache_root):
    out = os.path.join(cache_root, name, "output")
    if not os.path.isfile(out):
        continue
    mtime = os.path.getmtime(out)
    size  = os.path.getsize(out)
    # Strip digest suffix: last _<12+ hex chars> at end of name
    key = re.sub(r'_[0-9a-f]{12,}$', '', name)
    groups.setdefault(key, []).append((mtime, size, os.path.join(cache_root, name)))

total_freed = 0
total_deleted = 0

for key, items in sorted(groups.items()):
    if len(items) <= 1:
        continue
    # Sort by mtime descending; keep first (newest), delete the rest
    items.sort(key=lambda x: x[0], reverse=True)
    for mtime, size, path in items[1:]:
        if dry_run:
            print(f"[dry-run] would remove {path}  ({size/(1024*1024):.1f} MB)")
        else:
            print(f"removing {path}  ({size/(1024*1024):.1f} MB)")
            shutil.rmtree(path, ignore_errors=True)
        total_freed += size
        total_deleted += 1

if total_deleted == 0:
    print("oci2bin prune: nothing to remove")
else:
    verb = "would free" if dry_run else "freed"
    mb   = total_freed / (1024 * 1024)
    print(f"oci2bin prune: {total_deleted} entr{'y' if total_deleted==1 else 'ies'} removed, {verb} {mb:.1f} MB")
PYEOF
    exit 0
fi

# ── diff subcommand ───────────────────────────────────────────────────────

if [[ "${1:-}" == "diff" ]]; then
    shift
    if [[ "${1:-}" == "--live" ]]; then
        shift
        if [[ $# -lt 2 ]]; then
            echo "Usage: oci2bin diff --live PID BINARY" >&2
            exit 1
        fi
        DIFF_PID="$1"; shift
        DIFF_BINARY="$1"; shift
        if ! [[ "$DIFF_PID" =~ ^[0-9]+$ ]]; then
            echo "oci2bin diff: PID must be a positive integer" >&2
            exit 1
        fi
        if [[ ! -d "/proc/$DIFF_PID/root" ]]; then
            echo "oci2bin diff: /proc/$DIFF_PID/root not accessible" >&2
            exit 1
        fi
        exec python3 "$OCI2BIN_HOME/scripts/diff_images.py" \
            --live "$DIFF_PID" "$DIFF_BINARY"
    fi
    if [[ $# -lt 2 ]]; then
        echo "Usage: oci2bin diff <binary1> <binary2>" >&2
        echo "       oci2bin diff --live PID BINARY" >&2
        exit 1
    fi
    exec python3 "$OCI2BIN_HOME/scripts/diff_images.py" "$1" "$2"
fi

# ── reconstruct subcommand ───────────────────────────────────────────────

if [[ "${1:-}" == "reconstruct" ]]; then
    shift
    exec python3 "$OCI2BIN_HOME/scripts/reconstruct.py" "$@"
fi

# ── push subcommand ───────────────────────────────────────────────────────

if [[ "${1:-}" == "push" ]]; then
    shift
    if [[ $# -lt 2 ]]; then
        echo "Usage: oci2bin push BINARY REGISTRY/IMAGE:TAG" >&2
        exit 1
    fi
    PUSH_BINARY="$1"
    PUSH_TARGET="$2"

    if [[ ! -f "$PUSH_BINARY" ]]; then
        echo "oci2bin push: binary not found: $PUSH_BINARY" >&2
        exit 1
    fi

    need docker

    echo "oci2bin push: loading $PUSH_BINARY into Docker..." >&2
    LOAD_OUTPUT="$(docker load < "$PUSH_BINARY" 2>&1)"
    LOADED_IMAGE="$(echo "$LOAD_OUTPUT" | grep -oP 'Loaded image: \K.*' | head -1)"

    if [[ -z "$LOADED_IMAGE" ]]; then
        echo "oci2bin push: docker load failed:" >&2
        echo "$LOAD_OUTPUT" >&2
        exit 1
    fi

    echo "oci2bin push: tagging as $PUSH_TARGET..." >&2
    docker tag "$LOADED_IMAGE" "$PUSH_TARGET"

    echo "oci2bin push: pushing to $PUSH_TARGET..." >&2
    docker push "$PUSH_TARGET"

    echo "oci2bin push: cleaning up..." >&2
    docker rmi "$PUSH_TARGET" 2>/dev/null || true
    [[ "$LOADED_IMAGE" != "$PUSH_TARGET" ]] && docker rmi "$LOADED_IMAGE" 2>/dev/null || true

    echo "oci2bin push: done → $PUSH_TARGET" >&2
    exit 0
fi

# ── sbom subcommand ───────────────────────────────────────────────────────

if [[ "${1:-}" == "sbom" ]]; then
    shift
    if [[ $# -lt 1 ]]; then
        echo "Usage: oci2bin sbom BINARY [--format spdx|cyclonedx]" >&2
        exit 1
    fi
    exec python3 "$OCI2BIN_HOME/scripts/sbom_generate.py" "$@"
fi

# ── update subcommand ─────────────────────────────────────────────────────

if [[ "${1:-}" == "update" ]]; then
    shift
    UPDATE_CHECK_ONLY=0
    UPDATE_VERIFY_KEY=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check)
                UPDATE_CHECK_ONLY=1
                shift
                ;;
            --verify-key)
                [[ $# -lt 2 ]] && { echo "oci2bin update: --verify-key requires PATH" >&2; exit 1; }
                UPDATE_VERIFY_KEY="$2"
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done
    if [[ $# -lt 1 ]]; then
        echo "Usage: oci2bin update [--check] [--verify-key PATH] BINARY" >&2
        exit 1
    fi
    UPDATE_BINARY="$1"
    if [[ ! -f "$UPDATE_BINARY" ]]; then
        echo "oci2bin update: binary not found: $UPDATE_BINARY" >&2
        exit 1
    fi

    # Read image name from embedded metadata block
    META_JSON="$(python3 - "$UPDATE_BINARY" "$OCI2BIN_HOME" <<'PYEOF'
import sys, os
binary = sys.argv[1]
home = sys.argv[2]
import importlib.util
spec = importlib.util.spec_from_file_location(
    "inspect_image",
    os.path.join(home, "scripts", "inspect_image.py"))
mod = importlib.util.module_from_spec(spec)
spec.loader.exec_module(mod)
meta = mod.read_meta_block(binary) or {}
if 'image' not in meta or not meta.get('image'):
    try:
        oci = mod.read_oci_data(binary)
        tags, _, _ = mod.parse_config(oci)
        meta['image'] = tags[0] if tags else ''
    except SystemExit:
        meta['image'] = ''
import json
print(json.dumps(meta))
PYEOF
)"

    IMAGE_NAME="$(python3 - "$META_JSON" <<'PYEOF'
import json, sys
meta = json.loads(sys.argv[1])
print(meta.get("image",""))
PYEOF
)"

    if [[ -z "$IMAGE_NAME" ]]; then
        echo "oci2bin update: could not read image name from $UPDATE_BINARY" >&2
        exit 1
    fi

    SELF_UPDATE_URL="$(python3 - "$META_JSON" <<'PYEOF'
import json, sys
meta = json.loads(sys.argv[1])
print(meta.get("self_update_url",""))
PYEOF
)"

    if [[ "$UPDATE_CHECK_ONLY" -eq 1 && -n "$SELF_UPDATE_URL" ]]; then
        SELF_ARGS=(--check-update)
        [[ -n "$UPDATE_VERIFY_KEY" ]] && SELF_ARGS+=(--verify-key "$UPDATE_VERIFY_KEY")
        exec "$UPDATE_BINARY" "${SELF_ARGS[@]}"
    fi

    CURRENT_DIGEST="$(python3 - "$META_JSON" <<'PYEOF'
import json, sys
meta = json.loads(sys.argv[1])
print(meta.get("digest",""))
PYEOF
)"

    if [[ "$UPDATE_CHECK_ONLY" -eq 1 ]]; then
        need docker
        docker pull "$IMAGE_NAME" >/dev/null 2>&1 || true
        NEW_DIGEST="$(docker inspect --format '{{index .RepoDigests 0}}' "$IMAGE_NAME" 2>/dev/null || true)"
        if [[ -z "$CURRENT_DIGEST" || -z "$NEW_DIGEST" ]]; then
            echo "oci2bin update: unable to compare digests for $IMAGE_NAME" >&2
            exit 1
        fi
        if [[ "$CURRENT_DIGEST" == "$NEW_DIGEST" ]]; then
            echo "oci2bin update: $UPDATE_BINARY is up to date ($NEW_DIGEST)" >&2
            exit 0
        fi
        echo "oci2bin update: update available" >&2
        echo "  current: $CURRENT_DIGEST" >&2
        echo "  latest:  $NEW_DIGEST" >&2
        exit 10
    fi

    echo "oci2bin update: rebuilding from $IMAGE_NAME..." >&2

    # Build to a temp file in the same directory (for atomic rename)
    UPDATE_DIR="$(dirname "$UPDATE_BINARY")"
    UPDATE_TMP="$(mktemp "$UPDATE_DIR/.oci2bin-update.XXXXXX")"
    # shellcheck disable=SC2064
    trap "rm -f \"$UPDATE_TMP\"" EXIT

    "$0" "$IMAGE_NAME" "$UPDATE_TMP"

    mv "$UPDATE_TMP" "$UPDATE_BINARY"
    chmod +x "$UPDATE_BINARY"
    trap - EXIT

    echo "oci2bin update: done → $UPDATE_BINARY" >&2
    exit 0
fi

# ── ps subcommand ─────────────────────────────────────────────────────────

