                echo "oci2bin pod: PID=$cpid exited with code $ec" >&2
                if [[ $ec -ne 0 && $ec -gt $WORST_EXIT ]]; then
                    WORST_EXIT=$ec
                fi
                if [[ $ec -ne 0 ]]; then
                    # Non-zero exit: SIGTERM all others
                    for other in "${REMAINING[@]}"; do
                        [[ "$other" != "$cpid" ]] && kill -TERM "$other" 2>/dev/null || true
                    done
                fi
            else
                NEW_REMAINING+=("$cpid")
            fi
        done
        REMAINING=("${NEW_REMAINING[@]}")
        [[ ${#REMAINING[@]} -gt 0 ]] && sleep 0.2
    done

    # Cleanup pause process
    kill "$PAUSE_BG" 2>/dev/null || true
    wait "$PAUSE_BG" 2>/dev/null || true

    exit "$WORST_EXIT"
fi

# ── argument parsing ──────────────────────────────────────────────────────

HOST_ARCH="$(uname -m)"
TARGET_ARCH="$HOST_ARCH"
USE_CACHE=0
LAYER_IMAGES=()
DO_STRIP=0
STRIP_PREFIX_ARGS=()
STRIP_AUTO=0
ADD_FILE_ARGS=()
ADD_DIR_ARGS=()
OCI_DIR=""
KERNEL_PATH=""
INITRAMFS_PATH=""
EMBED_LOADER_LAYER=0
EMBED_LOADER_LABELS=0
LABEL_CHUNK_SIZE=""
LOADER_DIR=""
LABEL_PREFIX=""
SELF_UPDATE_URL=""
PIN_DIGEST=""
VERIFY_COSIGN=0
REQUIRE_COSIGN=0
COSIGN_KEY=""
DO_SQUASH=0
COMPRESS_FORMAT=""
# Auto-detect libkrun; --no-libkrun opts out
if pkg-config --exists libkrun 2>/dev/null || ldconfig -p 2>/dev/null | grep -q libkrun; then
    USE_LIBKRUN=1
else
    USE_LIBKRUN=0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --arch)
            [[ $# -lt 2 ]] && { echo "oci2bin: --arch requires an argument" >&2; exit 1; }
            TARGET_ARCH="$2"
            shift 2
            ;;
        --no-auto-tmpfs)
            # pass-through runtime flag; handled by loader
            shift
            ;;
        --cache)
            USE_CACHE=1
            shift
            ;;
        --layer)
            [[ $# -lt 2 ]] && { echo "oci2bin: --layer requires an IMAGE argument" >&2; exit 1; }
            LAYER_IMAGES+=("$2")
            shift 2
            ;;
        --strip)
            DO_STRIP=1
            shift
            ;;
        --strip-prefix)
            [[ $# -lt 2 ]] && { echo "oci2bin: --strip-prefix requires PREFIX" >&2; exit 1; }
            # Reject absolute paths and '..' components
            if [[ "$2" == /* ]]; then
                echo "oci2bin: --strip-prefix must not start with '/'" >&2; exit 1
            fi
            if [[ "$2" =~ (^|/)\.\.(/|$) ]]; then
                echo "oci2bin: --strip-prefix must not contain '..'" >&2; exit 1
            fi
            DO_STRIP=1
            STRIP_PREFIX_ARGS+=("--strip-prefix" "$2")
            shift 2
            ;;
        --strip-auto)
            STRIP_AUTO=1
            shift
            ;;
        --add-file)
            [[ $# -lt 2 ]] && { echo "oci2bin: --add-file requires HOST:CONTAINER" >&2; exit 1; }
            ADD_FILE_ARGS+=("$2")
            shift 2
            ;;
        --add-dir)
            [[ $# -lt 2 ]] && { echo "oci2bin: --add-dir requires HOST:CONTAINER" >&2; exit 1; }
            ADD_DIR_ARGS+=("$2")
            shift 2
            ;;
        --oci-dir)
            [[ $# -lt 2 ]] && { echo "oci2bin: --oci-dir requires a DIR argument" >&2; exit 1; }
            OCI_DIR="$2"
            shift 2
            ;;
        --kernel)
            [[ $# -lt 2 ]] && { echo "oci2bin: --kernel requires a PATH argument" >&2; exit 1; }
            KERNEL_PATH="$2"
            shift 2
            ;;
        --initramfs)
            [[ $# -lt 2 ]] && { echo "oci2bin: --initramfs requires a PATH argument" >&2; exit 1; }
            INITRAMFS_PATH="$2"
            shift 2
            ;;
        --libkrun)
            USE_LIBKRUN=1
            shift
            ;;
        --no-libkrun)
            USE_LIBKRUN=0
            shift
            ;;
        --embed-loader-layer)
            EMBED_LOADER_LAYER=1
            shift
            ;;
        --embed-loader-labels)
            EMBED_LOADER_LABELS=1
            shift
            ;;
        --label-chunk-size)
            [[ $# -lt 2 ]] && { echo "oci2bin: --label-chunk-size requires a BYTES argument" >&2; exit 1; }
            LABEL_CHUNK_SIZE="$2"
            shift 2
            ;;
        --loader-dir)
            [[ $# -lt 2 ]] && { echo "oci2bin: --loader-dir requires a DIR argument" >&2; exit 1; }
            LOADER_DIR="$2"
            shift 2
            ;;
        --label-prefix)
            [[ $# -lt 2 ]] && { echo "oci2bin: --label-prefix requires a PREFIX argument" >&2; exit 1; }
            LABEL_PREFIX="$2"
            shift 2
            ;;
        --self-update-url)
            [[ $# -lt 2 ]] && { echo "oci2bin: --self-update-url requires a URL argument" >&2; exit 1; }
            SELF_UPDATE_URL="$2"
            shift 2
            ;;
        --pin-digest)
            [[ $# -lt 2 ]] && { echo "oci2bin: --pin-digest requires DIGEST or ALGO:auto" >&2; exit 1; }
            PIN_DIGEST="$2"
            shift 2
            ;;
        --verify-cosign)
            VERIFY_COSIGN=1; shift ;;
        --require-cosign)
            VERIFY_COSIGN=1; REQUIRE_COSIGN=1; shift ;;
        --cosign-key)
            [[ $# -lt 2 ]] && { echo "oci2bin: --cosign-key requires PATH" >&2; exit 1; }
            COSIGN_KEY="$2"; shift 2 ;;
        --squash)
            DO_SQUASH=1; shift ;;
        --compress)
            [[ $# -lt 2 ]] && { echo "oci2bin: --compress requires gzip|zstd" >&2; exit 1; }
            case "$2" in
                gzip|zstd) ;;
                *) echo "oci2bin: --compress: unsupported format '$2' (use gzip or zstd)" >&2; exit 1 ;;
            esac
            COMPRESS_FORMAT="$2"; shift 2 ;;
        --help|-h)
            usage
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -lt 1 ]]; then
    usage
fi

IMAGE="$1"
# Derive output name from image: "nginx:1.25" -> "nginx_1.25"
# In oci2vm mode prefix with "oci2vm_" so the loader's basename check fires.
if [[ "$OCI2VM_MODE" -eq 1 ]]; then
    OUTPUT="${2:-oci2vm_${IMAGE//[:\/]/_}}"
else
    OUTPUT="${2:-${IMAGE//[:\/]/_}}"
fi
shift 2 2>/dev/null || shift 1

# Parse any remaining flags that follow the positional args (e.g. --kernel, --initramfs)
while [[ $# -gt 0 ]]; do
    case "$1" in
        --kernel)
            [[ $# -lt 2 ]] && { echo "oci2bin: --kernel requires a PATH argument" >&2; exit 1; }
            KERNEL_PATH="$2"; shift 2 ;;
        --initramfs)
            [[ $# -lt 2 ]] && { echo "oci2bin: --initramfs requires a PATH argument" >&2; exit 1; }
            INITRAMFS_PATH="$2"; shift 2 ;;
        *)
            echo "oci2bin: unexpected argument: $1" >&2; exit 1 ;;
    esac
done

# ── architecture / compiler selection ─────────────────────────────────────

# Handle --arch all: build for all supported architectures and produce a
# wrapper script that detects the running arch and delegates to the right
# binary.  Both arch-specific binaries are placed next to the output.
if [[ "$TARGET_ARCH" == "all" ]]; then
    # Recursively invoke oci2bin for each target arch
    MULTI_ARCH_ARCHS=("x86_64" "aarch64")
    MULTI_ARCH_OUTPUTS=()
    for a in "${MULTI_ARCH_ARCHS[@]}"; do
        out_a="${OUTPUT}_${a}"
        echo "oci2bin: building for $a → $out_a" >&2
        env_args=()
        [[ -n "${OCI2BIN_HOME:-}" ]] && env_args=(env "OCI2BIN_HOME=$OCI2BIN_HOME")
        # Rebuild arg list without --arch all
        _rebuild_args=()
        _skip_next=0
        for arg in "$@"; do
            if [[ "$_skip_next" -eq 1 ]]; then _skip_next=0; continue; fi
            _rebuild_args+=("$arg")
        done
        "${env_args[@]}" "$0" --arch "$a" "${_rebuild_args[@]}" "$IMAGE" "$out_a"
        MULTI_ARCH_OUTPUTS+=("$out_a")
    done

    # Write the wrapper script that auto-selects the right binary
    cat > "$OUTPUT" <<WRAPPER_EOF
#!/bin/sh
_ARCH=\$(uname -m)
_DIR=\$(dirname "\$0")
case "\$_ARCH" in
    x86_64)  exec "\$_DIR/${OUTPUT}_x86_64" "\$@" ;;
    aarch64) exec "\$_DIR/${OUTPUT}_aarch64" "\$@" ;;
    *)
        echo "oci2bin: unsupported architecture: \$_ARCH" >&2
        exit 1
        ;;
esac
WRAPPER_EOF
    chmod +x "$OUTPUT"
    echo "oci2bin: multi-arch wrapper → $OUTPUT"
    echo "oci2bin: arch binaries: ${MULTI_ARCH_OUTPUTS[*]}"
    exit 0
fi

if [[ "$TARGET_ARCH" == "$HOST_ARCH" ]]; then
    CC_CROSS="gcc"
    CFLAGS_CROSS=""
elif [[ "$TARGET_ARCH" == "aarch64" && "$HOST_ARCH" == "x86_64" ]]; then
    CC_CROSS="aarch64-linux-gnu-gcc"
    AARCH64_SYSROOT="${AARCH64_SYSROOT:-/usr/aarch64-redhat-linux/sys-root/fc43}"
    CFLAGS_CROSS="--sysroot=$AARCH64_SYSROOT -isystem $AARCH64_SYSROOT/usr/include"
else
    echo "oci2bin: cross-compilation from $HOST_ARCH to $TARGET_ARCH is not supported" >&2
    exit 1
fi

# ── dependency checks ─────────────────────────────────────────────────────

need() {
    command -v "$1" >/dev/null 2>&1 || { echo "oci2bin: '$1' not found in PATH" >&2; exit 1; }
}
need "$CC_CROSS"
need python3
need docker

# ── build loader if needed ────────────────────────────────────────────────

SRC="$OCI2BIN_HOME/src/loader.c"
if [[ "$USE_LIBKRUN" -eq 1 ]]; then
    LOADER="$OCI2BIN_HOME/build/loader-libkrun-$TARGET_ARCH"
    if [[ ! -f "$LOADER" || "$SRC" -nt "$LOADER" ]]; then
        echo "oci2bin: building loader with libkrun for $TARGET_ARCH..."
        mkdir -p "$OCI2BIN_HOME/build"
        $CC_CROSS $CFLAGS_CROSS -O2 -s -DUSE_LIBKRUN ${VM_CPUS:+-DDEFAULT_VM_CPUS=$VM_CPUS} ${VM_MEM_MB:+-DDEFAULT_VM_MEM_MB=$VM_MEM_MB} -o "$LOADER" "$SRC" -lkrun
    fi
else
    LOADER="$OCI2BIN_HOME/build/loader-$TARGET_ARCH"
    if [[ ! -f "$LOADER" || "$SRC" -nt "$LOADER" ]]; then
        echo "oci2bin: building loader for $TARGET_ARCH..."
        mkdir -p "$OCI2BIN_HOME/build"
        $CC_CROSS $CFLAGS_CROSS -static -O2 -s ${VM_CPUS:+-DDEFAULT_VM_CPUS=$VM_CPUS} ${VM_MEM_MB:+-DDEFAULT_VM_MEM_MB=$VM_MEM_MB} -o "$LOADER" "$SRC"
    fi
fi

# ── OCI image layout: convert to docker-save tar, skip docker entirely ────

if [[ -n "$OCI_DIR" ]]; then
    if [[ ! -d "$OCI_DIR" ]]; then
        echo "oci2bin: --oci-dir: directory not found: $OCI_DIR" >&2
        exit 1
    fi
    OCI_TMPDIR="$(mktemp -d)"
    trap 'rm -rf "$OCI_TMPDIR"' EXIT
    OCI_TAR="$OCI_TMPDIR/oci_image.tar"
    echo "oci2bin: converting OCI image layout from $OCI_DIR..."
    python3 "$OCI2BIN_HOME/scripts/oci_layout_to_tar.py" \
        --oci-dir "$OCI_DIR" \
        --output  "$OCI_TAR" \
        ${IMAGE:+--tag "$IMAGE"}
    BUILD_TAR_ARG="$OCI_TAR"
    BUILD_IMAGE_ARG="${IMAGE:-local/image:latest}"
    # Jump straight to add-files/build steps — no docker pull/digest needed
else

# ── pull image if not local ───────────────────────────────────────────────

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
    echo "oci2bin: pulling $IMAGE..."
    docker pull "$IMAGE"
fi

# ── cosign image signature verification ──────────────────────────────────

if [[ "$VERIFY_COSIGN" -eq 1 ]]; then
    if command -v cosign >/dev/null 2>&1; then
        echo "oci2bin: verifying image signature with cosign..." >&2
        COSIGN_ARGS=(cosign verify)
        [[ -n "$COSIGN_KEY" ]] && COSIGN_ARGS+=(--key "$COSIGN_KEY")
        COSIGN_ARGS+=("$IMAGE")
        if "${COSIGN_ARGS[@]}" >/dev/null 2>&1; then
            echo "oci2bin: cosign verification passed" >&2
        else
            if [[ "$REQUIRE_COSIGN" -eq 1 ]]; then
                echo "oci2bin: cosign verification failed (--require-cosign)" >&2
                exit 1
            else
                echo "oci2bin: warning: cosign verification failed" >&2
            fi
        fi
    else
        if [[ "$REQUIRE_COSIGN" -eq 1 ]]; then
            echo "oci2bin: cosign not installed (--require-cosign)" >&2
            exit 1
        else
            echo "oci2bin: warning: cosign not installed, skipping verification" >&2
        fi
    fi
fi

# ── get image digest for cache key and reproducibility ────────────────────
#
# docker inspect returns the content-addressed digest (e.g. repo@sha256:abc...)
# so cache keys are tied to a specific image content, not just the tag name.
# This prevents silent tag drift where redis:latest changes but the cached
# binary was built from an older version.

DIGEST=""
DIGEST_SHORT=""
if DIGEST="$(docker inspect --format '{{index .RepoDigests 0}}' "$IMAGE" 2>/dev/null)"; then
    if [[ -n "$DIGEST" ]]; then
        # Extract the sha256 hex part
        sha256_part="${DIGEST##*sha256:}"
        DIGEST_SHORT="${sha256_part:0:12}"
        echo "oci2bin: image digest: $DIGEST" >&2
    fi
else
    echo "oci2bin: warning: could not determine image digest (no registry origin?)" >&2
fi

# Update cache key to include digest so different content gets separate entries
if [[ "$USE_CACHE" -eq 1 && -n "$DIGEST_SHORT" ]]; then
    CACHE_KEY="${IMAGE//[:\/]/_}_${DIGEST_SHORT}"
    CACHE_DIR="$HOME/.cache/oci2bin/$CACHE_KEY"
    if [[ -s "$CACHE_DIR/output" ]]; then
        echo "oci2bin: cache hit (digest $DIGEST_SHORT) → $OUTPUT"
        cp "$CACHE_DIR/output" "$OUTPUT"
        chmod +x "$OUTPUT"
        exit 0
    fi
fi  # end of non-oci-dir docker path

fi  # close: if [[ -n "$OCI_DIR" ]]; then ... else ... fi

# ── merge layers if --layer was given ─────────────────────────────────────

if [[ "${#LAYER_IMAGES[@]}" -gt 0 ]]; then
    MERGE_TMPDIR="$(mktemp -d)"
    trap 'rm -rf "$MERGE_TMPDIR"' EXIT

    # Save base image
    BASE_TAR="$MERGE_TMPDIR/base.tar"
    echo "oci2bin: saving base image $IMAGE..."
    docker save -o "$BASE_TAR" "$IMAGE"

    MERGE_ARGS=(--base "$BASE_TAR")

    # Save each --layer image
    idx=0
    for layer_img in "${LAYER_IMAGES[@]}"; do
        if ! docker image inspect "$layer_img" >/dev/null 2>&1; then
            echo "oci2bin: pulling layer image $layer_img..."
            docker pull "$layer_img"
        fi
        layer_tar="$MERGE_TMPDIR/layer${idx}.tar"
        echo "oci2bin: saving layer image $layer_img..."
        docker save -o "$layer_tar" "$layer_img"
        MERGE_ARGS+=(--layer "$layer_tar")
        idx=$((idx + 1))
    done

    MERGED_TAR="$MERGE_TMPDIR/merged.tar"
    python3 "$OCI2BIN_HOME/scripts/merge_layers.py" \
        "${MERGE_ARGS[@]}" --output "$MERGED_TAR"

    # Build polyglot from merged tar (pass via stdin workaround: use temp image name)
    # build_polyglot.py accepts --tar directly via docker save output path
    BUILD_IMAGE_ARG="$IMAGE"
    BUILD_TAR_ARG="$MERGED_TAR"
else
    # Only set defaults if not already set by --oci-dir
    BUILD_IMAGE_ARG="${BUILD_IMAGE_ARG:-$IMAGE}"
    BUILD_TAR_ARG="${BUILD_TAR_ARG:-}"
fi

# ── strip if requested ────────────────────────────────────────────────────

if [[ "$DO_STRIP" -eq 1 ]]; then
    # Need a tar to strip — save now if not already saved by --layer logic
    if [[ -z "$BUILD_TAR_ARG" ]]; then
        STRIP_TMPDIR="$(mktemp -d)"
        trap 'rm -rf "$STRIP_TMPDIR"' EXIT
        BASE_TAR_FOR_STRIP="$STRIP_TMPDIR/base.tar"
        echo "oci2bin: saving $IMAGE for stripping..."
        docker save -o "$BASE_TAR_FOR_STRIP" "$IMAGE"
        BUILD_TAR_ARG="$BASE_TAR_FOR_STRIP"
    fi
    STRIPPED_TAR="${BUILD_TAR_ARG%.tar}_stripped.tar"
    echo "oci2bin: stripping docs/man/locale from image..."
    python3 "$OCI2BIN_HOME/scripts/strip_image.py" \
        --input  "$BUILD_TAR_ARG" \
        --output "$STRIPPED_TAR" \
        "${STRIP_PREFIX_ARGS[@]+"${STRIP_PREFIX_ARGS[@]}"}" \
        $([[ "$STRIP_AUTO" -eq 1 ]] && echo "--autodetect")
    BUILD_TAR_ARG="$STRIPPED_TAR"
fi

# ── squash layers if requested ────────────────────────────────────────────

if [[ "$DO_SQUASH" -eq 1 ]]; then
    if [[ -z "$BUILD_TAR_ARG" ]]; then
        SQUASH_TMPDIR="$(mktemp -d)"
        trap 'rm -rf "$SQUASH_TMPDIR"' EXIT
        BASE_TAR_FOR_SQUASH="$SQUASH_TMPDIR/base.tar"
        echo "oci2bin: saving $IMAGE for squashing..."
        docker save -o "$BASE_TAR_FOR_SQUASH" "$IMAGE"
        BUILD_TAR_ARG="$BASE_TAR_FOR_SQUASH"
    fi
    SQUASHED_TAR="${BUILD_TAR_ARG%.tar}_squashed.tar"
    echo "oci2bin: squashing layers..."
    SQUASH_ARGS=(python3 "$OCI2BIN_HOME/scripts/squash_layers.py"
        --input  "$BUILD_TAR_ARG"
        --output "$SQUASHED_TAR")
    [[ -n "$COMPRESS_FORMAT" ]] && SQUASH_ARGS+=(--compress "$COMPRESS_FORMAT")
    "${SQUASH_ARGS[@]}"
    BUILD_TAR_ARG="$SQUASHED_TAR"
fi

# ── inject --add-file / --add-dir if requested ────────────────────────────

if [[ "${#ADD_FILE_ARGS[@]}" -gt 0 || "${#ADD_DIR_ARGS[@]}" -gt 0 ]]; then
    # Need a tar to inject into — save now if not already saved
    if [[ -z "$BUILD_TAR_ARG" ]]; then
        INJECT_TMPDIR="$(mktemp -d)"
        trap 'rm -rf "$INJECT_TMPDIR"' EXIT
        BASE_TAR_FOR_INJECT="$INJECT_TMPDIR/base.tar"
        echo "oci2bin: saving $IMAGE for file injection..."
        docker save -o "$BASE_TAR_FOR_INJECT" "$IMAGE"
        BUILD_TAR_ARG="$BASE_TAR_FOR_INJECT"
    fi
    INJECTED_TAR="${BUILD_TAR_ARG%.tar}_injected.tar"

    INJECT_ARGS=()
    for f in "${ADD_FILE_ARGS[@]}"; do INJECT_ARGS+=(--file "$f"); done
    for d in "${ADD_DIR_ARGS[@]}";  do INJECT_ARGS+=(--dir  "$d"); done

    echo "oci2bin: injecting files/dirs into image..."
    python3 "$OCI2BIN_HOME/scripts/add_files.py" \
        --input  "$BUILD_TAR_ARG" \
        --output "$INJECTED_TAR" \
        "${INJECT_ARGS[@]}"
    BUILD_TAR_ARG="$INJECTED_TAR"
fi

# ── build polyglot ────────────────────────────────────────────────────────

# Build common extra args for metadata embedding
DIGEST_ARG=()
[[ -n "${DIGEST:-}" ]] && DIGEST_ARG=(--digest "$DIGEST")
KERNEL_ARG=()
[[ -n "$KERNEL_PATH" ]] && KERNEL_ARG=(--kernel "$KERNEL_PATH")
INITRAMFS_ARG=()
[[ -n "$INITRAMFS_PATH" ]] && INITRAMFS_ARG=(--initramfs "$INITRAMFS_PATH")
EMBED_LOADER_ARG=()
[[ "$EMBED_LOADER_LAYER"  -eq 1 ]] && EMBED_LOADER_ARG=(--embed-loader-layer)
[[ "$EMBED_LOADER_LABELS" -eq 1 ]] && EMBED_LOADER_ARG=(--embed-loader-labels)
[[ -n "$LABEL_CHUNK_SIZE" ]] && EMBED_LOADER_ARG+=(--label-chunk-size "$LABEL_CHUNK_SIZE")
[[ -n "$LOADER_DIR"       ]] && EMBED_LOADER_ARG+=(--loader-dir "$LOADER_DIR")
[[ -n "$LABEL_PREFIX"     ]] && EMBED_LOADER_ARG+=(--label-prefix "$LABEL_PREFIX")
[[ -n "$SELF_UPDATE_URL"  ]] && EMBED_LOADER_ARG+=(--self-update-url "$SELF_UPDATE_URL")
[[ -n "$PIN_DIGEST"       ]] && EMBED_LOADER_ARG+=(--pin-digest "$PIN_DIGEST")

if [[ -n "$BUILD_TAR_ARG" ]]; then
    python3 "$OCI2BIN_HOME/scripts/build_polyglot.py" \
        --loader     "$LOADER" \
        --image      "$BUILD_IMAGE_ARG" \
        --tar        "$BUILD_TAR_ARG" \
        --image-name "$IMAGE" \
        "${DIGEST_ARG[@]}" \
        "${KERNEL_ARG[@]}" \
        "${INITRAMFS_ARG[@]}" \
        "${EMBED_LOADER_ARG[@]}" \
        --output     "$OUTPUT"
else
    python3 "$OCI2BIN_HOME/scripts/build_polyglot.py" \
        --loader     "$LOADER" \
        --image      "$IMAGE" \
        --image-name "$IMAGE" \
        "${DIGEST_ARG[@]}" \
        "${KERNEL_ARG[@]}" \
        "${INITRAMFS_ARG[@]}" \
        "${EMBED_LOADER_ARG[@]}" \
        --output     "$OUTPUT"
fi

# ── populate cache if requested ───────────────────────────────────────────

if [[ "$USE_CACHE" -eq 1 && -n "${CACHE_DIR:-}" ]]; then
    mkdir -p "$CACHE_DIR"
    cp "$OUTPUT" "$CACHE_DIR/output"
fi

echo "oci2bin: done → $OUTPUT"
