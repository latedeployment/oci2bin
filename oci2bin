#!/usr/bin/env bash
# oci2bin — package a Docker image as a self-contained ELF+tar polyglot
#
# Usage:
#   oci2bin [--arch ARCH] <image[:tag]> [output]
#   oci2bin inspect <binary>
#   oci2bin sign   --key KEY.pem  --in BINARY [--out BINARY]
#   oci2bin verify --key PUB.pem  --in BINARY
#   oci2bin pod run [--net shared] [--ipc shared] BINARY [BINARY ...]
#   oci2bin list [--json]
#   oci2bin prune [--dry-run]
#   oci2bin diff <binary1> <binary2>
#
# The output file runs as a rootless container AND can be imported with
# docker load. It accepts the same runtime flags as the embedded loader:
#
#   ./output [OPTIONS] [-- CMD [ARGS...]]
#   ./output [OPTIONS] CMD [ARGS...]
#
# Build options:
#   --arch ARCH           Target architecture: x86_64 (default) or aarch64
#                         Cross-compilation requires the matching musl cross-
#                         compiler (aarch64-linux-musl-gcc) to be in PATH.
#   --cache               Cache the output binary; skip rebuild if already built
#   --layer IMAGE         Merge additional image layers on top of the base image
#                         (may be repeated; layers are applied in order)
#   --strip               Remove docs/man/locale/cache from the image before packaging
#   --add-file HOST:CONTAINER
#                         Inject a host file into the image at build time (repeatable)
#   --add-dir  HOST:CONTAINER
#                         Inject a host directory recursively (repeatable)
#   --oci-dir DIR         Use an OCI image layout directory instead of docker save
#                         (skips docker pull/save; IMAGE arg used only for naming)
#
# Runtime options (passed directly to the output binary):
#   -v HOST:CONTAINER     Bind mount a host path into the container
#   --secret HOST_FILE[:CONTAINER_PATH]
#                         Bind mount a host file read-only into the container;
#                         defaults to /run/secrets/<basename> (may be repeated)
#   --entrypoint PATH     Override the image entrypoint
#   --workdir PATH        Set the working directory inside the container
#   --net host|none|slirp|pasta|slirp:H:C
#                         Network: host (default), none (isolated),
#                         slirp (slirp4netns), pasta, or slirp with port forward
#   --read-only           Mount rootfs read-only via overlayfs
#   --overlay-persist DIR Persist overlay upper layer to DIR (state survives restarts)
#   --ssh-agent           Forward host SSH_AUTH_SOCK into the container
#   --no-seccomp          Disable the default seccomp syscall filter
#   --user UID[:GID]      Run as this numeric UID (and optional GID)
#   --hostname NAME       Set the hostname inside the container
#   --cap-drop CAP        Drop a Linux capability (or 'all' to drop all)
#   --cap-add CAP         Add an ambient capability (use after --cap-drop all)
#   --device /dev/PATH[:CONTAINER_PATH]
#                         Expose a host device inside the container
#   --init                Run a zombie-reaping init as PID 1
#   --detach, -d          Run container in background; print PID to stdout
#   --memory SIZE         Limit memory (e.g. 512m, 2g) via cgroup v2
#   --cpus FLOAT          Limit CPU fraction (e.g. 0.5) via cgroup v2
#   --pids-limit N        Limit total PIDs via cgroup v2
#   --verify-key PATH     Verify signature before extraction (abort if invalid)
#   --env-file FILE       Load KEY=VALUE pairs from FILE (additive with -e)
#   --tmpfs PATH          Mount a fresh tmpfs at PATH inside the container
#   --ulimit TYPE=N       Set resource limit (nofile, nproc, cpu, as, fsize)
#   --config PATH         Load options from a key=value config file
#   --                    End of options; remaining args are CMD
#
# Cache subcommands:
#   list [--json]         List all cached binaries with image name, size, date
#   prune [--dry-run]     Remove outdated cache entries (keep newest per image)
#   diff <b1> <b2>        Show filesystem diff between two oci2bin binaries
#
# Examples:
#   oci2bin alpine:latest               # -> alpine_latest (host arch)
#   oci2bin --arch aarch64 alpine:latest # -> alpine_latest (aarch64 binary)
#   oci2bin ubuntu:22.04 my-ubuntu      # -> my-ubuntu (explicit name)
#
#   ./alpine_latest                     # run default shell
#   ./alpine_latest /bin/ls /           # override CMD
#   ./alpine_latest --entrypoint /bin/sh -c "echo hi"
#   ./alpine_latest -v /data:/mnt /bin/ls /mnt
#
#   oci2bin list                        # show cached binaries
#   oci2bin prune                       # remove old cache entries
#   oci2bin diff alpine_latest redis_7  # compare two binaries

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OCI2BIN_HOME="${OCI2BIN_HOME:-$SCRIPT_DIR}"

usage() {
    grep '^#' "$0" | grep -v '#!/' | sed 's/^# \?//'
    exit 1
}

# ── inspect subcommand ────────────────────────────────────────────────────

if [[ "${1:-}" == "inspect" ]]; then
    shift
    if [[ $# -lt 1 ]]; then
        echo "Usage: oci2bin inspect <binary>" >&2
        exit 1
    fi
    exec python3 "$OCI2BIN_HOME/scripts/inspect_image.py" "$@"
fi

# ── sign subcommand ───────────────────────────────────────────────────────

if [[ "${1:-}" == "sign" ]]; then
    shift
    exec python3 "$OCI2BIN_HOME/scripts/sign_binary.py" sign "$@"
fi

# ── verify subcommand ─────────────────────────────────────────────────────

if [[ "${1:-}" == "verify" ]]; then
    shift
    exec python3 "$OCI2BIN_HOME/scripts/sign_binary.py" verify "$@"
fi

# ── list subcommand ───────────────────────────────────────────────────────

if [[ "${1:-}" == "list" ]]; then
    shift
    CACHE_ROOT="$HOME/.cache/oci2bin"
    LIST_JSON=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) LIST_JSON=1; shift ;;
            *) echo "oci2bin list: unknown option: $1" >&2; exit 1 ;;
        esac
    done
    if [[ ! -d "$CACHE_ROOT" ]]; then
        echo "oci2bin: no cache found at $CACHE_ROOT" >&2
        exit 0
    fi
    python3 - "$CACHE_ROOT" "$LIST_JSON" "$OCI2BIN_HOME" <<'PYEOF'
import json, os, sys

cache_root = sys.argv[1]
want_json  = sys.argv[2] == "1"
home       = sys.argv[3]
inspect    = os.path.join(home, "scripts", "inspect_image.py")

import importlib.util, types

# Load inspect_image module without executing main()
spec = importlib.util.spec_from_file_location("inspect_image", inspect)
mod  = importlib.util.module_from_spec(spec)
spec.loader.exec_module(mod)

entries = []
for name in sorted(os.listdir(cache_root)):
    out = os.path.join(cache_root, name, "output")
    if not os.path.isfile(out):
        continue
    file_size = os.path.getsize(out)
    mtime = os.path.getmtime(out)
    meta = mod.read_meta_block(out) or {}
    if "image" not in meta:
        try:
            oci = mod.read_oci_data(out)
            tags, _, _ = mod.parse_config(oci)
            meta["image"] = tags[0] if tags else "unknown"
        except SystemExit:
            meta["image"] = "unknown"
    meta["size"]  = file_size
    meta["mtime"] = mtime
    meta["cache_dir"] = name
    entries.append(meta)

# Sort by build timestamp descending, fall back to mtime
def sort_key(e):
    ts = e.get("timestamp") or ""
    return (ts, e.get("mtime", 0))

entries.sort(key=sort_key, reverse=True)

if want_json:
    print(json.dumps(entries, indent=2))
else:
    # Print table
    FMT = "%-32s %-14s %10s  %s"
    print(FMT % ("IMAGE", "DIGEST", "SIZE", "BUILT"))
    print("-" * 76)
    for e in entries:
        image  = (e.get("image") or "unknown")[:32]
        digest = (e.get("digest","").split(":")[-1])[:12] if e.get("digest") else "-" * 12
        sz     = e["size"]
        if sz >= 1024*1024:
            size_s = f"{sz/(1024*1024):.1f} MB"
        elif sz >= 1024:
            size_s = f"{sz/1024:.1f} KB"
        else:
            size_s = f"{sz} B"
        built  = (e.get("timestamp") or "-")[:19]
        print(FMT % (image, digest, size_s, built))
PYEOF
    exit 0
fi

# ── prune subcommand ──────────────────────────────────────────────────────

if [[ "${1:-}" == "prune" ]]; then
    shift
    CACHE_ROOT="$HOME/.cache/oci2bin"
    PRUNE_DRY_RUN=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) PRUNE_DRY_RUN=1; shift ;;
            *) echo "oci2bin prune: unknown option: $1" >&2; exit 1 ;;
        esac
    done
    if [[ ! -d "$CACHE_ROOT" ]]; then
        echo "oci2bin: no cache found at $CACHE_ROOT" >&2
        exit 0
    fi
    python3 - "$CACHE_ROOT" "$PRUNE_DRY_RUN" "$OCI2BIN_HOME" <<'PYEOF'
import json, os, shutil, sys

cache_root = sys.argv[1]
dry_run    = sys.argv[2] == "1"
home       = sys.argv[3]
inspect    = os.path.join(home, "scripts", "inspect_image.py")

import importlib.util

spec = importlib.util.spec_from_file_location("inspect_image", inspect)
mod  = importlib.util.module_from_spec(spec)
spec.loader.exec_module(mod)

# Collect all cache entries keyed by base image name
# Cache dir names look like "redis_7-alpine_abc123def456" — strip the trailing
# _<12hexchars> digest suffix to get the image group key.
import re

groups = {}  # image_key -> list of (mtime, size, cache_dir_path)
for name in os.listdir(cache_root):
    out = os.path.join(cache_root, name, "output")
    if not os.path.isfile(out):
        continue
    mtime = os.path.getmtime(out)
    size  = os.path.getsize(out)
    # Strip digest suffix: last _<12+ hex chars> at end of name
    key = re.sub(r'_[0-9a-f]{12,}$', '', name)
    groups.setdefault(key, []).append((mtime, size, os.path.join(cache_root, name)))

total_freed = 0
total_deleted = 0

for key, items in sorted(groups.items()):
    if len(items) <= 1:
        continue
    # Sort by mtime descending; keep first (newest), delete the rest
    items.sort(key=lambda x: x[0], reverse=True)
    for mtime, size, path in items[1:]:
        if dry_run:
            print(f"[dry-run] would remove {path}  ({size/(1024*1024):.1f} MB)")
        else:
            print(f"removing {path}  ({size/(1024*1024):.1f} MB)")
            shutil.rmtree(path, ignore_errors=True)
        total_freed += size
        total_deleted += 1

if total_deleted == 0:
    print("oci2bin prune: nothing to remove")
else:
    verb = "would free" if dry_run else "freed"
    mb   = total_freed / (1024 * 1024)
    print(f"oci2bin prune: {total_deleted} entr{'y' if total_deleted==1 else 'ies'} removed, {verb} {mb:.1f} MB")
PYEOF
    exit 0
fi

# ── diff subcommand ───────────────────────────────────────────────────────

if [[ "${1:-}" == "diff" ]]; then
    shift
    if [[ $# -lt 2 ]]; then
        echo "Usage: oci2bin diff <binary1> <binary2>" >&2
        exit 1
    fi
    exec python3 "$OCI2BIN_HOME/scripts/diff_images.py" "$1" "$2"
fi

# ── pod subcommand ────────────────────────────────────────────────────────

if [[ "${1:-}" == "pod" ]]; then
    shift
    if [[ "${1:-}" != "run" ]]; then
        echo "Usage: oci2bin pod run [--net shared] [--ipc shared] BINARY [BINARY ...]" >&2
        exit 1
    fi
    shift  # consume "run"

    POD_NET_SHARED=0
    POD_IPC_SHARED=0
    POD_BINARIES=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --net)
                [[ "${2:-}" == "shared" ]] || { echo "oci2bin pod: --net only supports 'shared'" >&2; exit 1; }
                POD_NET_SHARED=1; shift 2 ;;
            --ipc)
                [[ "${2:-}" == "shared" ]] || { echo "oci2bin pod: --ipc only supports 'shared'" >&2; exit 1; }
                POD_IPC_SHARED=1; shift 2 ;;
            -*)
                echo "oci2bin pod: unknown option: $1" >&2; exit 1 ;;
            *)
                POD_BINARIES+=("$1"); shift ;;
        esac
    done

    if [[ ${#POD_BINARIES[@]} -eq 0 ]]; then
        echo "oci2bin pod run: at least one BINARY is required" >&2
        exit 1
    fi

    for b in "${POD_BINARIES[@]}"; do
        [[ -x "$b" ]] || { echo "oci2bin pod: $b is not executable" >&2; exit 1; }
    done

    # Create a pause process to hold the shared namespaces
    PAUSE_PID_FILE="$(mktemp)"
    PAUSE_NET_FLAG=""
    PAUSE_IPC_FLAG=""
    [[ $POD_NET_SHARED -eq 1 ]] && PAUSE_NET_FLAG="--net"
    [[ $POD_IPC_SHARED -eq 1 ]] && PAUSE_IPC_FLAG="--ipc"
    # shellcheck disable=SC2086
    unshare $PAUSE_NET_FLAG $PAUSE_IPC_FLAG -- sh -c "echo \$\$ > \"$PAUSE_PID_FILE\"; exec sleep infinity" &
    PAUSE_BG=$!
    # Give unshare a moment to start
    sleep 0.1
    PAUSE_PID=$(cat "$PAUSE_PID_FILE")
    rm -f "$PAUSE_PID_FILE"

    echo "oci2bin pod: pause PID=$PAUSE_PID" >&2

    # Start each binary joining the pause process's namespaces
    CHILD_PIDS=()
    WORST_EXIT=0

    for b in "${POD_BINARIES[@]}"; do
        CHILD_FLAGS=()
        [[ $POD_NET_SHARED -eq 1 ]] && CHILD_FLAGS+=("--net" "container:$PAUSE_PID")
        [[ $POD_IPC_SHARED -eq 1 ]] && CHILD_FLAGS+=("--ipc" "container:$PAUSE_PID")
        "$b" "${CHILD_FLAGS[@]}" &
        cid=$!
        CHILD_PIDS+=("$cid")
        echo "oci2bin pod: started $b (PID=$cid)" >&2
    done

    # Forward SIGTERM/SIGINT to all children
    _pod_signal() {
        local sig="$1"
        for cpid in "${CHILD_PIDS[@]}"; do
            kill "-$sig" "$cpid" 2>/dev/null || true
        done
    }
    trap '_pod_signal TERM' TERM
    trap '_pod_signal INT' INT

    # Monitor: wait for any child to exit; if non-zero, SIGTERM others
    REMAINING=("${CHILD_PIDS[@]}")
    while [[ ${#REMAINING[@]} -gt 0 ]]; do
        NEW_REMAINING=()
        for cpid in "${REMAINING[@]}"; do
            if ! kill -0 "$cpid" 2>/dev/null; then
                wait "$cpid" 2>/dev/null; ec=$?
                echo "oci2bin pod: PID=$cpid exited with code $ec" >&2
                if [[ $ec -ne 0 && $ec -gt $WORST_EXIT ]]; then
                    WORST_EXIT=$ec
                fi
                if [[ $ec -ne 0 ]]; then
                    # Non-zero exit: SIGTERM all others
                    for other in "${REMAINING[@]}"; do
                        [[ "$other" != "$cpid" ]] && kill -TERM "$other" 2>/dev/null || true
                    done
                fi
            else
                NEW_REMAINING+=("$cpid")
            fi
        done
        REMAINING=("${NEW_REMAINING[@]}")
        [[ ${#REMAINING[@]} -gt 0 ]] && sleep 0.2
    done

    # Cleanup pause process
    kill "$PAUSE_BG" 2>/dev/null || true
    wait "$PAUSE_BG" 2>/dev/null || true

    exit "$WORST_EXIT"
fi

# ── argument parsing ──────────────────────────────────────────────────────

HOST_ARCH="$(uname -m)"
TARGET_ARCH="$HOST_ARCH"
USE_CACHE=0
LAYER_IMAGES=()
DO_STRIP=0
ADD_FILE_ARGS=()
ADD_DIR_ARGS=()
OCI_DIR=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --arch)
            [[ $# -lt 2 ]] && { echo "oci2bin: --arch requires an argument" >&2; exit 1; }
            TARGET_ARCH="$2"
            shift 2
            ;;
        --cache)
            USE_CACHE=1
            shift
            ;;
        --layer)
            [[ $# -lt 2 ]] && { echo "oci2bin: --layer requires an IMAGE argument" >&2; exit 1; }
            LAYER_IMAGES+=("$2")
            shift 2
            ;;
        --strip)
            DO_STRIP=1
            shift
            ;;
        --add-file)
            [[ $# -lt 2 ]] && { echo "oci2bin: --add-file requires HOST:CONTAINER" >&2; exit 1; }
            ADD_FILE_ARGS+=("$2")
            shift 2
            ;;
        --add-dir)
            [[ $# -lt 2 ]] && { echo "oci2bin: --add-dir requires HOST:CONTAINER" >&2; exit 1; }
            ADD_DIR_ARGS+=("$2")
            shift 2
            ;;
        --oci-dir)
            [[ $# -lt 2 ]] && { echo "oci2bin: --oci-dir requires a DIR argument" >&2; exit 1; }
            OCI_DIR="$2"
            shift 2
            ;;
        --help|-h)
            usage
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -lt 1 ]]; then
    usage
fi

IMAGE="$1"
# Derive output name from image: "nginx:1.25" -> "nginx_1.25"
OUTPUT="${2:-${IMAGE//[:\/]/_}}"

# ── architecture / compiler selection ─────────────────────────────────────

if [[ "$TARGET_ARCH" == "$HOST_ARCH" ]]; then
    CC_CROSS="gcc"
    CFLAGS_CROSS=""
elif [[ "$TARGET_ARCH" == "aarch64" && "$HOST_ARCH" == "x86_64" ]]; then
    CC_CROSS="aarch64-linux-gnu-gcc"
    AARCH64_SYSROOT="${AARCH64_SYSROOT:-/usr/aarch64-redhat-linux/sys-root/fc43}"
    CFLAGS_CROSS="--sysroot=$AARCH64_SYSROOT -isystem $AARCH64_SYSROOT/usr/include"
else
    echo "oci2bin: cross-compilation from $HOST_ARCH to $TARGET_ARCH is not supported" >&2
    exit 1
fi

# ── dependency checks ─────────────────────────────────────────────────────

need() {
    command -v "$1" >/dev/null 2>&1 || { echo "oci2bin: '$1' not found in PATH" >&2; exit 1; }
}
need "$CC_CROSS"
need python3
need docker

# ── build loader if needed ────────────────────────────────────────────────

LOADER="$OCI2BIN_HOME/build/loader-$TARGET_ARCH"
SRC="$OCI2BIN_HOME/src/loader.c"

if [[ ! -f "$LOADER" || "$SRC" -nt "$LOADER" ]]; then
    echo "oci2bin: building loader for $TARGET_ARCH..."
    mkdir -p "$OCI2BIN_HOME/build"
    $CC_CROSS $CFLAGS_CROSS -static -O2 -s -o "$LOADER" "$SRC"
fi

# ── OCI image layout: convert to docker-save tar, skip docker entirely ────

if [[ -n "$OCI_DIR" ]]; then
    if [[ ! -d "$OCI_DIR" ]]; then
        echo "oci2bin: --oci-dir: directory not found: $OCI_DIR" >&2
        exit 1
    fi
    OCI_TMPDIR="$(mktemp -d)"
    trap 'rm -rf "$OCI_TMPDIR"' EXIT
    OCI_TAR="$OCI_TMPDIR/oci_image.tar"
    echo "oci2bin: converting OCI image layout from $OCI_DIR..."
    python3 "$OCI2BIN_HOME/scripts/oci_layout_to_tar.py" \
        --oci-dir "$OCI_DIR" \
        --output  "$OCI_TAR" \
        ${IMAGE:+--tag "$IMAGE"}
    BUILD_TAR_ARG="$OCI_TAR"
    BUILD_IMAGE_ARG="${IMAGE:-local/image:latest}"
    # Jump straight to add-files/build steps — no docker pull/digest needed
else

# ── pull image if not local ───────────────────────────────────────────────

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
    echo "oci2bin: pulling $IMAGE..."
    docker pull "$IMAGE"
fi

# ── get image digest for cache key and reproducibility ────────────────────
#
# docker inspect returns the content-addressed digest (e.g. repo@sha256:abc...)
# so cache keys are tied to a specific image content, not just the tag name.
# This prevents silent tag drift where redis:latest changes but the cached
# binary was built from an older version.

DIGEST=""
DIGEST_SHORT=""
if DIGEST="$(docker inspect --format '{{index .RepoDigests 0}}' "$IMAGE" 2>/dev/null)"; then
    if [[ -n "$DIGEST" ]]; then
        # Extract the sha256 hex part
        sha256_part="${DIGEST##*sha256:}"
        DIGEST_SHORT="${sha256_part:0:12}"
        echo "oci2bin: image digest: $DIGEST" >&2
    fi
else
    echo "oci2bin: warning: could not determine image digest (no registry origin?)" >&2
fi

# Update cache key to include digest so different content gets separate entries
if [[ "$USE_CACHE" -eq 1 && -n "$DIGEST_SHORT" ]]; then
    CACHE_KEY="${IMAGE//[:\/]/_}_${DIGEST_SHORT}"
    CACHE_DIR="$HOME/.cache/oci2bin/$CACHE_KEY"
    if [[ -s "$CACHE_DIR/output" ]]; then
        echo "oci2bin: cache hit (digest $DIGEST_SHORT) → $OUTPUT"
        cp "$CACHE_DIR/output" "$OUTPUT"
        chmod +x "$OUTPUT"
        exit 0
    fi
fi  # end of non-oci-dir docker path

fi  # close: if [[ -n "$OCI_DIR" ]]; then ... else ... fi

# ── merge layers if --layer was given ─────────────────────────────────────

if [[ "${#LAYER_IMAGES[@]}" -gt 0 ]]; then
    MERGE_TMPDIR="$(mktemp -d)"
    trap 'rm -rf "$MERGE_TMPDIR"' EXIT

    # Save base image
    BASE_TAR="$MERGE_TMPDIR/base.tar"
    echo "oci2bin: saving base image $IMAGE..."
    docker save -o "$BASE_TAR" "$IMAGE"

    MERGE_ARGS=(--base "$BASE_TAR")

    # Save each --layer image
    idx=0
    for layer_img in "${LAYER_IMAGES[@]}"; do
        if ! docker image inspect "$layer_img" >/dev/null 2>&1; then
            echo "oci2bin: pulling layer image $layer_img..."
            docker pull "$layer_img"
        fi
        layer_tar="$MERGE_TMPDIR/layer${idx}.tar"
        echo "oci2bin: saving layer image $layer_img..."
        docker save -o "$layer_tar" "$layer_img"
        MERGE_ARGS+=(--layer "$layer_tar")
        idx=$((idx + 1))
    done

    MERGED_TAR="$MERGE_TMPDIR/merged.tar"
    python3 "$OCI2BIN_HOME/scripts/merge_layers.py" \
        "${MERGE_ARGS[@]}" --output "$MERGED_TAR"

    # Build polyglot from merged tar (pass via stdin workaround: use temp image name)
    # build_polyglot.py accepts --tar directly via docker save output path
    BUILD_IMAGE_ARG="$IMAGE"
    BUILD_TAR_ARG="$MERGED_TAR"
else
    # Only set defaults if not already set by --oci-dir
    BUILD_IMAGE_ARG="${BUILD_IMAGE_ARG:-$IMAGE}"
    BUILD_TAR_ARG="${BUILD_TAR_ARG:-}"
fi

# ── strip if requested ────────────────────────────────────────────────────

if [[ "$DO_STRIP" -eq 1 ]]; then
    # Need a tar to strip — save now if not already saved by --layer logic
    if [[ -z "$BUILD_TAR_ARG" ]]; then
        STRIP_TMPDIR="$(mktemp -d)"
        trap 'rm -rf "$STRIP_TMPDIR"' EXIT
        BASE_TAR_FOR_STRIP="$STRIP_TMPDIR/base.tar"
        echo "oci2bin: saving $IMAGE for stripping..."
        docker save -o "$BASE_TAR_FOR_STRIP" "$IMAGE"
        BUILD_TAR_ARG="$BASE_TAR_FOR_STRIP"
    fi
    STRIPPED_TAR="${BUILD_TAR_ARG%.tar}_stripped.tar"
    echo "oci2bin: stripping docs/man/locale from image..."
    python3 "$OCI2BIN_HOME/scripts/strip_image.py" \
        --input  "$BUILD_TAR_ARG" \
        --output "$STRIPPED_TAR"
    BUILD_TAR_ARG="$STRIPPED_TAR"
fi

# ── inject --add-file / --add-dir if requested ────────────────────────────

if [[ "${#ADD_FILE_ARGS[@]}" -gt 0 || "${#ADD_DIR_ARGS[@]}" -gt 0 ]]; then
    # Need a tar to inject into — save now if not already saved
    if [[ -z "$BUILD_TAR_ARG" ]]; then
        INJECT_TMPDIR="$(mktemp -d)"
        trap 'rm -rf "$INJECT_TMPDIR"' EXIT
        BASE_TAR_FOR_INJECT="$INJECT_TMPDIR/base.tar"
        echo "oci2bin: saving $IMAGE for file injection..."
        docker save -o "$BASE_TAR_FOR_INJECT" "$IMAGE"
        BUILD_TAR_ARG="$BASE_TAR_FOR_INJECT"
    fi
    INJECTED_TAR="${BUILD_TAR_ARG%.tar}_injected.tar"

    INJECT_ARGS=()
    for f in "${ADD_FILE_ARGS[@]}"; do INJECT_ARGS+=(--file "$f"); done
    for d in "${ADD_DIR_ARGS[@]}";  do INJECT_ARGS+=(--dir  "$d"); done

    echo "oci2bin: injecting files/dirs into image..."
    python3 "$OCI2BIN_HOME/scripts/add_files.py" \
        --input  "$BUILD_TAR_ARG" \
        --output "$INJECTED_TAR" \
        "${INJECT_ARGS[@]}"
    BUILD_TAR_ARG="$INJECTED_TAR"
fi

# ── build polyglot ────────────────────────────────────────────────────────

# Build common extra args for metadata embedding
DIGEST_ARG=()
[[ -n "${DIGEST:-}" ]] && DIGEST_ARG=(--digest "$DIGEST")

if [[ -n "$BUILD_TAR_ARG" ]]; then
    python3 "$OCI2BIN_HOME/scripts/build_polyglot.py" \
        --loader     "$LOADER" \
        --image      "$BUILD_IMAGE_ARG" \
        --tar        "$BUILD_TAR_ARG" \
        --image-name "$IMAGE" \
        "${DIGEST_ARG[@]}" \
        --output     "$OUTPUT"
else
    python3 "$OCI2BIN_HOME/scripts/build_polyglot.py" \
        --loader     "$LOADER" \
        --image      "$IMAGE" \
        --image-name "$IMAGE" \
        "${DIGEST_ARG[@]}" \
        --output     "$OUTPUT"
fi

# ── populate cache if requested ───────────────────────────────────────────

if [[ "$USE_CACHE" -eq 1 && -n "${CACHE_DIR:-}" ]]; then
    mkdir -p "$CACHE_DIR"
    cp "$OUTPUT" "$CACHE_DIR/output"
fi

echo "oci2bin: done → $OUTPUT"
