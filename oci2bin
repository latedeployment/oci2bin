import json
import os
import sys
import time
from pathlib import Path

STATE_DIR = Path(sys.argv[3])
CLK_TCK = os.sysconf(os.sysconf_names["SC_CLK_TCK"])
PAGESIZE = os.sysconf("SC_PAGE_SIZE")
CPU_COUNT = max(1, os.cpu_count() or 1)


def read_stat(pid):
    with open(f"/proc/{pid}/stat", "r", encoding="utf-8") as f:
        raw = f.read().strip()
    rparen = raw.rfind(")")
    fields = raw[rparen + 2:].split()
    utime = int(fields[11])
    stime = int(fields[12])
    starttime = int(fields[19])
    rss = int(fields[21]) * PAGESIZE
    return utime + stime, starttime, rss


def cgroup_relpath(pid):
    try:
        with open(f"/proc/{pid}/cgroup", "r", encoding="utf-8") as f:
            for line in f:
                parts = line.strip().split(":", 2)
                if len(parts) == 3 and parts[0] == "0":
                    return parts[2]
    except OSError:
        return None
    return None


def cgroup_read(relpath, name):
    if not relpath:
        return None
    path = Path("/sys/fs/cgroup") / relpath.lstrip("/") / name
    try:
        return path.read_text(encoding="utf-8").strip()
    except OSError:
        return None


def format_bytes(value):
    value = float(value)
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if value < 1024.0 or unit == "TB":
            return f"{value:.1f}{unit}" if unit != "B" else f"{int(value)}B"
        value /= 1024.0


def format_uptime(seconds):
    seconds = max(0, int(seconds))
    days, seconds = divmod(seconds, 86400)
    hours, seconds = divmod(seconds, 3600)
    minutes, seconds = divmod(seconds, 60)
    if days:
        return f"{days}d{hours:02}h"
    if hours:
        return f"{hours}h{minutes:02}m"
    return f"{minutes}m{seconds:02}s"


def snapshot():
    boot = time.time() - float(Path("/proc/uptime").read_text().split()[0])
    rows = []
    if not STATE_DIR.is_dir():
        return rows
    for state in sorted(STATE_DIR.glob("*.json")):
        if state.is_symlink():
            continue
        try:
            info = json.loads(state.read_text(encoding="utf-8"))
            pid = int(info.get("pid", 0))
        except (OSError, ValueError, json.JSONDecodeError):
            continue
        if pid <= 0 or not Path(f"/proc/{pid}").exists():
            continue
        try:
            cpu_ticks, starttime, rss = read_stat(pid)
        except OSError:
            continue
        relpath = cgroup_relpath(pid)
        mem = cgroup_read(relpath, "memory.current")
        pids_current = cgroup_read(relpath, "pids.current")
        rows.append({
            "name": info.get("name", state.stem),
            "pid": pid,
            "binary": os.path.basename(info.get("binary", "?")),
            "cpu_ticks": cpu_ticks,
            "memory": int(mem) if mem and mem.isdigit() else rss,
            "pids": int(pids_current) if pids_current and pids_current.isdigit()
                    else len(os.listdir(f"/proc/{pid}/task")),
            "uptime": time.time() - (boot + (starttime / CLK_TCK)),
        })
    return rows


def render(rows, prev_rows, interval, once):
    lines = []
    lines.append("NAME                 PID    CPU%   MEMORY     PIDS  UPTIME   BINARY")
    lines.append("-" * 76)
    prev_map = {row["pid"]: row for row in prev_rows}
    for row in rows:
        prev = prev_map.get(row["pid"])
        cpu_pct = 0.0
        if prev:
            delta = row["cpu_ticks"] - prev["cpu_ticks"]
            cpu_pct = max(0.0, (delta / CLK_TCK) / interval * 100.0)
        lines.append(
            f"{row['name'][:20]:20} {row['pid']:6d} {cpu_pct:6.1f} "
            f"{format_bytes(row['memory']):>9} {row['pids']:5d} "
            f"{format_uptime(row['uptime']):>8}   {row['binary'][:20]}"
        )
    if once:
        print("\n".join(lines))
    else:
        sys.stdout.write("\x1b[H\x1b[2J" + "\n".join(lines) + "\n")
        sys.stdout.flush()


once = sys.argv[1] == "1"
try:
    interval = float(sys.argv[2])
except ValueError:
    print("oci2bin top: --interval must be a positive number", file=sys.stderr)
    sys.exit(1)
if interval <= 0:
    print("oci2bin top: --interval must be a positive number", file=sys.stderr)
    sys.exit(1)
prev = snapshot()
if once:
    render(prev, [], interval, True)
    sys.exit(0)
while True:
    time.sleep(interval)
    cur = snapshot()
    render(cur, prev, interval, False)
    prev = cur
PYEOF
fi

