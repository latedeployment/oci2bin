#!/usr/bin/env bash
# oci2bin — package a Docker image as a self-contained ELF+tar polyglot
#
# Usage:
#   oci2bin [--arch ARCH] <image[:tag]> [output]
#   oci2bin inspect <binary>
#
# The output file runs as a rootless container AND can be imported with
# docker load. It accepts the same runtime flags as the embedded loader:
#
#   ./output [OPTIONS] [-- CMD [ARGS...]]
#   ./output [OPTIONS] CMD [ARGS...]
#
# Build options:
#   --arch ARCH           Target architecture: x86_64 (default) or aarch64
#                         Cross-compilation requires the matching musl cross-
#                         compiler (aarch64-linux-musl-gcc) to be in PATH.
#   --cache               Cache the output binary; skip rebuild if already built
#   --layer IMAGE         Merge additional image layers on top of the base image
#                         (may be repeated; layers are applied in order)
#   --strip               Remove docs/man/locale/cache from the image before packaging
#
# Runtime options (passed directly to the output binary):
#   -v HOST:CONTAINER     Bind mount a host path into the container
#   --secret HOST_FILE[:CONTAINER_PATH]
#                         Bind mount a host file read-only into the container;
#                         defaults to /run/secrets/<basename> (may be repeated)
#   --entrypoint PATH     Override the image entrypoint
#   --workdir PATH        Set the working directory inside the container
#   --net host|none       Network mode: host (default) or none (isolated)
#   --read-only           Mount rootfs read-only via overlayfs
#   --ssh-agent           Forward host SSH_AUTH_SOCK into the container
#   --no-seccomp          Disable the default seccomp syscall filter
#   --user UID[:GID]      Run as this numeric UID (and optional GID)
#   --hostname NAME       Set the hostname inside the container
#   --cap-drop CAP        Drop a Linux capability (or 'all' to drop all)
#   --cap-add CAP         Add an ambient capability (use after --cap-drop all)
#   --device /dev/PATH[:CONTAINER_PATH]
#                         Expose a host device inside the container
#   --init                Run a zombie-reaping init as PID 1
#   --detach, -d          Run container in background; print PID to stdout
#   --env-file FILE       Load KEY=VALUE pairs from FILE (additive with -e)
#   --tmpfs PATH          Mount a fresh tmpfs at PATH inside the container
#   --ulimit TYPE=N       Set resource limit (nofile, nproc, cpu, as, fsize)
#   --                    End of options; remaining args are CMD
#
# Examples:
#   oci2bin alpine:latest               # -> alpine_latest (host arch)
#   oci2bin --arch aarch64 alpine:latest # -> alpine_latest (aarch64 binary)
#   oci2bin ubuntu:22.04 my-ubuntu      # -> my-ubuntu (explicit name)
#
#   ./alpine_latest                     # run default shell
#   ./alpine_latest /bin/ls /           # override CMD
#   ./alpine_latest --entrypoint /bin/sh -c "echo hi"
#   ./alpine_latest -v /data:/mnt /bin/ls /mnt

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OCI2BIN_HOME="${OCI2BIN_HOME:-$SCRIPT_DIR}"

usage() {
    grep '^#' "$0" | grep -v '#!/' | sed 's/^# \?//'
    exit 1
}

# ── inspect subcommand ────────────────────────────────────────────────────

if [[ "${1:-}" == "inspect" ]]; then
    shift
    if [[ $# -lt 1 ]]; then
        echo "Usage: oci2bin inspect <binary>" >&2
        exit 1
    fi
    exec python3 "$OCI2BIN_HOME/scripts/inspect_image.py" "$1"
fi

# ── argument parsing ──────────────────────────────────────────────────────

HOST_ARCH="$(uname -m)"
TARGET_ARCH="$HOST_ARCH"
USE_CACHE=0
LAYER_IMAGES=()
DO_STRIP=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --arch)
            [[ $# -lt 2 ]] && { echo "oci2bin: --arch requires an argument" >&2; exit 1; }
            TARGET_ARCH="$2"
            shift 2
            ;;
        --cache)
            USE_CACHE=1
            shift
            ;;
        --layer)
            [[ $# -lt 2 ]] && { echo "oci2bin: --layer requires an IMAGE argument" >&2; exit 1; }
            LAYER_IMAGES+=("$2")
            shift 2
            ;;
        --strip)
            DO_STRIP=1
            shift
            ;;
        --help|-h)
            usage
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -lt 1 ]]; then
    usage
fi

IMAGE="$1"
# Derive output name from image: "nginx:1.25" -> "nginx_1.25"
OUTPUT="${2:-${IMAGE//[:\/]/_}}"

# ── architecture / compiler selection ─────────────────────────────────────

if [[ "$TARGET_ARCH" == "$HOST_ARCH" ]]; then
    CC_CROSS="gcc"
    CFLAGS_CROSS=""
elif [[ "$TARGET_ARCH" == "aarch64" && "$HOST_ARCH" == "x86_64" ]]; then
    CC_CROSS="aarch64-linux-gnu-gcc"
    AARCH64_SYSROOT="${AARCH64_SYSROOT:-/usr/aarch64-redhat-linux/sys-root/fc43}"
    CFLAGS_CROSS="--sysroot=$AARCH64_SYSROOT -isystem $AARCH64_SYSROOT/usr/include"
else
    echo "oci2bin: cross-compilation from $HOST_ARCH to $TARGET_ARCH is not supported" >&2
    exit 1
fi

# ── dependency checks ─────────────────────────────────────────────────────

need() {
    command -v "$1" >/dev/null 2>&1 || { echo "oci2bin: '$1' not found in PATH" >&2; exit 1; }
}
need "$CC_CROSS"
need python3
need docker

# ── build loader if needed ────────────────────────────────────────────────

LOADER="$OCI2BIN_HOME/build/loader-$TARGET_ARCH"
SRC="$OCI2BIN_HOME/src/loader.c"

if [[ ! -f "$LOADER" || "$SRC" -nt "$LOADER" ]]; then
    echo "oci2bin: building loader for $TARGET_ARCH..."
    mkdir -p "$OCI2BIN_HOME/build"
    $CC_CROSS $CFLAGS_CROSS -static -O2 -s -o "$LOADER" "$SRC"
fi

# ── pull image if not local ───────────────────────────────────────────────

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
    echo "oci2bin: pulling $IMAGE..."
    docker pull "$IMAGE"
fi

# ── get image digest for cache key and reproducibility ────────────────────
#
# docker inspect returns the content-addressed digest (e.g. repo@sha256:abc...)
# so cache keys are tied to a specific image content, not just the tag name.
# This prevents silent tag drift where redis:latest changes but the cached
# binary was built from an older version.

DIGEST=""
DIGEST_SHORT=""
if DIGEST="$(docker inspect --format '{{index .RepoDigests 0}}' "$IMAGE" 2>/dev/null)"; then
    if [[ -n "$DIGEST" ]]; then
        # Extract the sha256 hex part
        sha256_part="${DIGEST##*sha256:}"
        DIGEST_SHORT="${sha256_part:0:12}"
        echo "oci2bin: image digest: $DIGEST" >&2
    fi
else
    echo "oci2bin: warning: could not determine image digest (no registry origin?)" >&2
fi

# Update cache key to include digest so different content gets separate entries
if [[ "$USE_CACHE" -eq 1 && -n "$DIGEST_SHORT" ]]; then
    CACHE_KEY="${IMAGE//[:\/]/_}_${DIGEST_SHORT}"
    CACHE_DIR="$HOME/.cache/oci2bin/$CACHE_KEY"
    if [[ -s "$CACHE_DIR/output" ]]; then
        echo "oci2bin: cache hit (digest $DIGEST_SHORT) → $OUTPUT"
        cp "$CACHE_DIR/output" "$OUTPUT"
        chmod +x "$OUTPUT"
        exit 0
    fi
fi

# ── merge layers if --layer was given ─────────────────────────────────────

if [[ "${#LAYER_IMAGES[@]}" -gt 0 ]]; then
    MERGE_TMPDIR="$(mktemp -d)"
    trap 'rm -rf "$MERGE_TMPDIR"' EXIT

    # Save base image
    BASE_TAR="$MERGE_TMPDIR/base.tar"
    echo "oci2bin: saving base image $IMAGE..."
    docker save -o "$BASE_TAR" "$IMAGE"

    MERGE_ARGS=(--base "$BASE_TAR")

    # Save each --layer image
    idx=0
    for layer_img in "${LAYER_IMAGES[@]}"; do
        if ! docker image inspect "$layer_img" >/dev/null 2>&1; then
            echo "oci2bin: pulling layer image $layer_img..."
            docker pull "$layer_img"
        fi
        layer_tar="$MERGE_TMPDIR/layer${idx}.tar"
        echo "oci2bin: saving layer image $layer_img..."
        docker save -o "$layer_tar" "$layer_img"
        MERGE_ARGS+=(--layer "$layer_tar")
        idx=$((idx + 1))
    done

    MERGED_TAR="$MERGE_TMPDIR/merged.tar"
    python3 "$OCI2BIN_HOME/scripts/merge_layers.py" \
        "${MERGE_ARGS[@]}" --output "$MERGED_TAR"

    # Build polyglot from merged tar (pass via stdin workaround: use temp image name)
    # build_polyglot.py accepts --tar directly via docker save output path
    BUILD_IMAGE_ARG="$IMAGE"
    BUILD_TAR_ARG="$MERGED_TAR"
else
    BUILD_IMAGE_ARG="$IMAGE"
    BUILD_TAR_ARG=""
fi

# ── strip if requested ────────────────────────────────────────────────────

if [[ "$DO_STRIP" -eq 1 ]]; then
    # Need a tar to strip — save now if not already saved by --layer logic
    if [[ -z "$BUILD_TAR_ARG" ]]; then
        STRIP_TMPDIR="$(mktemp -d)"
        trap 'rm -rf "$STRIP_TMPDIR"' EXIT
        BASE_TAR_FOR_STRIP="$STRIP_TMPDIR/base.tar"
        echo "oci2bin: saving $IMAGE for stripping..."
        docker save -o "$BASE_TAR_FOR_STRIP" "$IMAGE"
        BUILD_TAR_ARG="$BASE_TAR_FOR_STRIP"
    fi
    STRIPPED_TAR="${BUILD_TAR_ARG%.tar}_stripped.tar"
    echo "oci2bin: stripping docs/man/locale from image..."
    python3 "$OCI2BIN_HOME/scripts/strip_image.py" \
        --input  "$BUILD_TAR_ARG" \
        --output "$STRIPPED_TAR"
    BUILD_TAR_ARG="$STRIPPED_TAR"
fi

# ── build polyglot ────────────────────────────────────────────────────────

# Build common extra args for metadata embedding
DIGEST_ARG=()
[[ -n "${DIGEST:-}" ]] && DIGEST_ARG=(--digest "$DIGEST")

if [[ -n "$BUILD_TAR_ARG" ]]; then
    python3 "$OCI2BIN_HOME/scripts/build_polyglot.py" \
        --loader     "$LOADER" \
        --image      "$BUILD_IMAGE_ARG" \
        --tar        "$BUILD_TAR_ARG" \
        --image-name "$IMAGE" \
        "${DIGEST_ARG[@]}" \
        --output     "$OUTPUT"
else
    python3 "$OCI2BIN_HOME/scripts/build_polyglot.py" \
        --loader     "$LOADER" \
        --image      "$IMAGE" \
        --image-name "$IMAGE" \
        "${DIGEST_ARG[@]}" \
        --output     "$OUTPUT"
fi

# ── populate cache if requested ───────────────────────────────────────────

if [[ "$USE_CACHE" -eq 1 && -n "${CACHE_DIR:-}" ]]; then
    mkdir -p "$CACHE_DIR"
    cp "$OUTPUT" "$CACHE_DIR/output"
fi

echo "oci2bin: done → $OUTPUT"
