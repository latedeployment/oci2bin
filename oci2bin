                POD_NET_SHARED=1; shift 2 ;;
            --ipc)
                [[ "${2:-}" == "shared" ]] || { echo "oci2bin pod: --ipc only supports 'shared'" >&2; exit 1; }
                POD_IPC_SHARED=1; shift 2 ;;
